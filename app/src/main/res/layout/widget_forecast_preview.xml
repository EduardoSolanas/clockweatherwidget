<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="10dp"
    tools:ignore="HardcodedText,SmallSp,NestedWeights,DisableBaselineAlignment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <include
            layout="@layout/widget_clock_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:format12Hour="EEE, MMM d"
            android:format24Hour="EEE, MMM d"
            android:layout_marginTop="4dp"
            android:layout_marginStart="0dp"
            android:textColor="@color/widget_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <include
            layout="@layout/widget_weather_card"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:baselineAligned="false"
        android:layout_weight="2"
        android:background="@drawable/weather_card_bg"
        android:orientation="horizontal"
        android:paddingTop="0dp"
        android:paddingBottom="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:padding="2dp">
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="Mon" android:textColor="@color/widget_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:src="@drawable/ic_widget_weather_clear_day" android:contentDescription="@null" android:padding="2dp" android:scaleType="fitCenter" />
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="17°/9°" android:textColor="@color/widget_text_primary" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:padding="2dp">
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="Tue" android:textColor="@color/widget_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:src="@drawable/ic_widget_weather_partly_cloudy_day" android:contentDescription="@null" android:padding="2dp" android:scaleType="fitCenter" />
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="16°/8°" android:textColor="@color/widget_text_primary" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:padding="2dp">
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="Wed" android:textColor="@color/widget_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:src="@drawable/ic_widget_weather_cloudy" android:contentDescription="@null" android:padding="2dp" android:scaleType="fitCenter" />
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="14°/7°" android:textColor="@color/widget_text_primary" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:padding="2dp">
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="Thu" android:textColor="@color/widget_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:src="@drawable/ic_widget_weather_rain" android:contentDescription="@null" android:padding="2dp" android:scaleType="fitCenter" />
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="12°/5°" android:textColor="@color/widget_text_primary" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:padding="2dp">
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="Fri" android:textColor="@color/widget_text_primary" android:textSize="13sp" android:textStyle="bold" android:gravity="center" />
            <ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" android:src="@drawable/ic_widget_weather_partly_cloudy_day" android:contentDescription="@null" android:padding="2dp" android:scaleType="fitCenter" />
            <TextView android:layout_width="wrap_content" android:layout_gravity="center_horizontal" android:layout_height="wrap_content" android:text="15°/7°" android:textColor="@color/widget_text_primary" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
