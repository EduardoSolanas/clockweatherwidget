<?xml version="1.0" encoding="utf-8"?>
<!-- Large Clock + Weather Widget (~4x3 cells) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- FLIP CLOCK ROW-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ViewFlipper android:animateFirstView="false"
            android:id="@+id/digit_h1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/flip_digit_bg"
            android:inAnimation="@anim/flip_in"
            android:outAnimation="@anim/flip_out">
            <TextView android:id="@+id/digit_h1_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h1_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
        </ViewFlipper>

        <ViewFlipper android:animateFirstView="false"
            android:id="@+id/digit_h2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:background="@drawable/flip_digit_bg"
            android:inAnimation="@anim/flip_in"
            android:outAnimation="@anim/flip_out">
            <TextView android:id="@+id/digit_h2_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_h2_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
        </ViewFlipper>

        <TextView
            android:id="@+id/colon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:text=":"
            android:textColor="@color/flip_digit_text"
            android:textSize="48sp"
            android:textStyle="bold" />

        <ViewFlipper android:animateFirstView="false"
            android:id="@+id/digit_m1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:background="@drawable/flip_digit_bg"
            android:inAnimation="@anim/flip_in"
            android:outAnimation="@anim/flip_out">
            <TextView android:id="@+id/digit_m1_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m1_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
        </ViewFlipper>

        <ViewFlipper android:animateFirstView="false"
            android:id="@+id/digit_m2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:background="@drawable/flip_digit_bg"
            android:inAnimation="@anim/flip_in"
            android:outAnimation="@anim/flip_out">
            <TextView android:id="@+id/digit_m2_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            <TextView android:id="@+id/digit_m2_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="0dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="52sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
        </ViewFlipper>

        <TextView
            android:id="@+id/ampm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="6dp"
            android:textColor="@color/flip_digit_text"
            android:textSize="@dimen/flip_ampm_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- WEATHER CARD-->
    <LinearLayout
        android:id="@+id/weather_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/widget_glass_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/city_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/condition_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/weather_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/current_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/high_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
