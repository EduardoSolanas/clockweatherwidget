<?xml version="1.0" encoding="utf-8"?>
<!-- Weather card: compact overlay; location/temp overlay on top of the icon. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/weather_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:background="@android:color/transparent"
    android:visibility="visible">

    <ImageView
        android:id="@+id/weather_icon"
        android:layout_width="196dp"
        android:layout_height="126dp"
        android:layout_gravity="bottom|center_horizontal"
        android:paddingBottom="10dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_widget_weather_partly_cloudy_day" />

    <!-- Location overlay (start) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/city_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="132dp"
            android:maxLines="1"
            android:text="London"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/condition_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Partly cloudy"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Temperature overlay (end) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:orientation="vertical">

        <TextView
            android:id="@+id/current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="17°C"
            android:textColor="@color/widget_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/high_low"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="20° / 11°"
            android:textColor="@color/widget_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
