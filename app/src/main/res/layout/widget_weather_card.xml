<?xml version="1.0" encoding="utf-8"?>
<!-- Weather card: compact overlay; location/temp overlay on top of the icon. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/weather_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:visibility="visible">

    <ImageView
        android:id="@+id/weather_icon"
        android:layout_width="196dp"
        android:layout_height="126dp"
        android:layout_gravity="bottom|center_horizontal"
        android:paddingBottom="10dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        tools:src="@drawable/ic_widget_weather_partly_cloudy_day" />

    <!-- Pre-12 icon variant: anchored to the card top with a negative margin so it
         overlaps the clock row regardless of widget height (matches the look taller
         hosts get naturally with the bottom-anchored icon). -->
    <ImageView
        android:id="@+id/weather_icon_top"
        android:layout_width="196dp"
        android:layout_height="126dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-56dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:visibility="gone"
        tools:src="@drawable/ic_widget_weather_partly_cloudy_day" />

    <!-- Location overlay (start) -->
    <LinearLayout
        android:id="@+id/weather_overlay_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/city_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="132dp"
            android:maxLines="1"
            android:text="London"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/condition_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Partly cloudy"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Temperature overlay (end). A centered FrameLayout child shifts up by the FULL
         bottom margin; half the location block's height (18dp) puts the temp block's
         vertical middle on the location text's top line. -->
    <LinearLayout
        android:id="@+id/weather_overlay_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginBottom="18dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="17°C"
            android:textColor="@color/widget_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/high_low"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="20° / 11°"
            android:textColor="@color/widget_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Pre-12 overlay variants: the card fills all leftover widget height, so the
         centered overlays sink far below the icon on tall hosts. These clones anchor
         to the card top, next to the icon. The binder writes both sets; the updater
         shows one pair per API level. -->
    <LinearLayout
        android:id="@+id/weather_overlay_location_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/city_name_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="132dp"
            android:maxLines="1"
            android:text="London"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/condition_text_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Partly cloudy"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/weather_overlay_temp_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="-17dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/current_temp_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="17°C"
            android:textColor="@color/widget_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/high_low_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="20° / 11°"
            android:textColor="@color/widget_text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_refresh"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="end|top"
        android:layout_marginTop="54dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/widget_refresh_weather"
        android:padding="4dp"
        android:src="@drawable/ic_widget_refresh" />
</FrameLayout>
