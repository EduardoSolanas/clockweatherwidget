<?xml version="1.0" encoding="utf-8"?>
<!-- Shared clock digit row — included in all widget layouts.
     Text size + colors are applied at runtime by BaseWidgetUpdater. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:id="@+id/digit_h1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/flip_digit_bg_light"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="8dp"
            android:text="0"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/flip_hinge_line" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/flip_digit_gap">
        <TextView
            android:id="@+id/digit_h2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/flip_digit_bg_light"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="8dp"
            android:text="0"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/flip_hinge_line" />
    </FrameLayout>

    <TextView
        android:id="@+id/colon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/flip_digit_gap"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text=":"
        android:textColor="#80000000"
        android:textSize="44sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:id="@+id/digit_m1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/flip_digit_bg_light"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="8dp"
            android:text="0"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/flip_hinge_line" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/flip_digit_gap">
        <TextView
            android:id="@+id/digit_m2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/flip_digit_bg_light"
            android:fontFamily="monospace"
            android:gravity="center"
            android:includeFontPadding="false"
            android:padding="8dp"
            android:text="0"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/flip_hinge_line" />
    </FrameLayout>

    <TextView
        android:id="@+id/ampm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="4dp"
        android:textColor="#80000000"
        android:textSize="@dimen/flip_ampm_text_size"
        android:textStyle="bold" />

</LinearLayout>
