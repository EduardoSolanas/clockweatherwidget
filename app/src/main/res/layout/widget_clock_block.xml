<?xml version="1.0" encoding="utf-8"?>
<!-- Shared clock row.
     Four visual tiles provide flip-card backgrounds; TextClock overlays the live
     hour/minute text. TextClocks start VISIBLE so the widget shows the correct
     time immediately on first placement. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:id="@+id/clock_hour_pair"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2">

        <LinearLayout
            android:id="@+id/hour_tiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/digit_h1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text=" "
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48dp"
                    android:textStyle="bold"
                    tools:ignore="SpUsage" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />

                <!-- Pre-12 digit: the clipper frame is one monospace glyph wide (0.6em of
                     48dp ≈ 28.8dp) and the TextClock inside has an exact two-glyph width,
                     so the frame clips one digit: layout_gravity left keeps the first
                     digit, right keeps the second. The exact child width is what makes
                     this safe — TextView never has to ellipsize or wrap. left/right (not
                     start/end) so RTL locales don't swap digits. -->
                <FrameLayout
                    android:layout_width="29dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <TextClock
                        android:id="@+id/tile_clock_h1"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:fontFamily="monospace"
                        android:format12Hour="hh"
                        android:format24Hour="HH"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/flip_digit_text_light"
                        android:textSize="48dp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:ignore="RtlHardcoded,SpUsage" />
                </FrameLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/flip_digit_gap"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/digit_h2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text=" "
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48dp"
                    android:textStyle="bold"
                    tools:ignore="SpUsage" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />

                <FrameLayout
                    android:layout_width="29dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <TextClock
                        android:id="@+id/tile_clock_h2"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:fontFamily="monospace"
                        android:format12Hour="hh"
                        android:format24Hour="HH"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/flip_digit_text_light"
                        android:textSize="48dp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:ignore="RtlHardcoded,SpUsage" />
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- On Android 12+ the updater spreads the two digits over their tiles with a
             computed setLetterSpacing (not remotable pre-12). Pre-12 the updater hides
             this spanning clock and shows the per-tile clipped TextClocks instead. -->
        <TextClock
            android:id="@+id/clock_hour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:format12Hour="hh"
            android:format24Hour="HH"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/flip_digit_text_light"
            android:textSize="48sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- The colon sits on the wallpaper (not on a tile), so it stays white
         regardless of the clock theme to remain visible on dark backgrounds. -->
    <TextView
        android:id="@+id/colon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/flip_digit_gap"
        android:layout_marginEnd="@dimen/flip_digit_gap"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text=":"
        android:textColor="@android:color/white"
        android:textSize="44sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/clock_minute_pair"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2">

        <LinearLayout
            android:id="@+id/minute_tiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/digit_m1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text=" "
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48dp"
                    android:textStyle="bold"
                    tools:ignore="SpUsage" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />

                <FrameLayout
                    android:layout_width="29dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <TextClock
                        android:id="@+id/tile_clock_m1"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:fontFamily="monospace"
                        android:format12Hour="mm"
                        android:format24Hour="mm"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/flip_digit_text_light"
                        android:textSize="48dp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:ignore="RtlHardcoded,SpUsage" />
                </FrameLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/flip_digit_gap"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/digit_m2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text=" "
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48dp"
                    android:textStyle="bold"
                    tools:ignore="SpUsage" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />

                <FrameLayout
                    android:layout_width="29dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">

                    <TextClock
                        android:id="@+id/tile_clock_m2"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:fontFamily="monospace"
                        android:format12Hour="mm"
                        android:format24Hour="mm"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textColor="@color/flip_digit_text_light"
                        android:textSize="48dp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:ignore="RtlHardcoded,SpUsage" />
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>

        <TextClock
            android:id="@+id/clock_minute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:format12Hour="mm"
            android:format24Hour="mm"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/flip_digit_text_light"
            android:textSize="48sp"
            android:textStyle="bold" />
    </FrameLayout>

    <TextClock
        android:id="@+id/ampm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="4dp"
        android:format12Hour="a"
        android:format24Hour=""
        android:textColor="@color/flip_digit_text_light"
        android:textSize="@dimen/flip_ampm_text_size"
        android:textStyle="bold" />

</LinearLayout>
