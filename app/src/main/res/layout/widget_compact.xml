<?xml version="1.0" encoding="utf-8"?>
<!-- Compact Clock + Weather Widget (~4x2 cells) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- FLIP CLOCK ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <ViewFlipper
                android:id="@+id/digit_h1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateFirstView="false"
                android:background="@drawable/flip_digit_bg"
                android:inAnimation="@anim/flip_in"
                android:outAnimation="@anim/flip_out">
                <TextView android:id="@+id/digit_h1_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h1_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            </ViewFlipper>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="#80000000" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:layout_weight="1">

            <ViewFlipper
                android:id="@+id/digit_h2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateFirstView="false"
                android:background="@drawable/flip_digit_bg"
                android:inAnimation="@anim/flip_in"
                android:outAnimation="@anim/flip_out">
                <TextView android:id="@+id/digit_h2_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_h2_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            </ViewFlipper>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="#80000000" />
        </FrameLayout>

        <TextView
            android:id="@+id/colon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/flip_digit_gap"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text=":"
            android:textColor="#80FFFFFF"
            android:textSize="44sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <ViewFlipper
                android:id="@+id/digit_m1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateFirstView="false"
                android:background="@drawable/flip_digit_bg"
                android:inAnimation="@anim/flip_in"
                android:outAnimation="@anim/flip_out">
                <TextView android:id="@+id/digit_m1_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m1_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            </ViewFlipper>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="#80000000" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:layout_weight="1">

            <ViewFlipper
                android:id="@+id/digit_m2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:animateFirstView="false"
                android:background="@drawable/flip_digit_bg"
                android:inAnimation="@anim/flip_in"
                android:outAnimation="@anim/flip_out">
                <TextView android:id="@+id/digit_m2_0" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="0" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_1" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="1" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_2" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="2" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_3" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="3" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_4" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="4" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_5" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="5" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_6" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="6" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_7" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="7" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_8" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="8" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
                <TextView android:id="@+id/digit_m2_9" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:text="9" android:gravity="center" android:textColor="@color/flip_digit_text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" android:includeFontPadding="false" />
            </ViewFlipper>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="#80000000" />
        </FrameLayout>

        <TextView
            android:id="@+id/ampm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="6dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="@dimen/flip_ampm_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:text="Mon, Mar 9"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/weather_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/weather_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/city_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/condition_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/weather_icon"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/current_temp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/widget_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/high_low"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
