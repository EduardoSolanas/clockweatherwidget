<?xml version="1.0" encoding="utf-8"?>
<!-- Compact Clock + Weather Widget (~4x2 cells) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- ═══ FLIP CLOCK ROW ═══ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Hour tens digit tile -->
        <TextView
            android:id="@+id/digit_h1"
            android:layout_width="@dimen/flip_digit_width"
            android:layout_height="@dimen/flip_digit_height"
            android:background="@drawable/flip_digit_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/flip_digit_text"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Hour ones digit tile -->
        <TextView
            android:id="@+id/digit_h2"
            android:layout_width="@dimen/flip_digit_width"
            android:layout_height="@dimen/flip_digit_height"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:background="@drawable/flip_digit_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/flip_digit_text"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Colon separator -->
        <TextView
            android:layout_width="@dimen/flip_colon_width"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text=":"
            android:textColor="@color/flip_colon_color"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Minute tens digit tile -->
        <TextView
            android:id="@+id/digit_m1"
            android:layout_width="@dimen/flip_digit_width"
            android:layout_height="@dimen/flip_digit_height"
            android:background="@drawable/flip_digit_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/flip_digit_text"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- Minute ones digit tile -->
        <TextView
            android:id="@+id/digit_m2"
            android:layout_width="@dimen/flip_digit_width"
            android:layout_height="@dimen/flip_digit_height"
            android:layout_marginStart="@dimen/flip_digit_gap"
            android:background="@drawable/flip_digit_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/flip_digit_text"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <!-- AM/PM label -->
        <TextView
            android:id="@+id/ampm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="4dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="@dimen/flip_ampm_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Date display — shown below clock, above weather card -->
    <TextView
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:text="Fri, Mar 6"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <!-- ═══ WEATHER INFO CARD ═══ -->
    <LinearLayout
        android:id="@+id/weather_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/weather_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Weather icon -->
        <ImageView
            android:id="@+id/weather_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />

        <!-- Location + condition -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/city_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/condition_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Temperature -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/current_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/high_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
