<?xml version="1.0" encoding="utf-8"?>
<!-- Static clock row for widget picker previews only.
     Uses fixed digit TextViews instead of TextClock overlays so each
     character centres perfectly inside its flip-card tile. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    tools:ignore="HardcodedText">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text="1"
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/flip_digit_gap"
                android:layout_weight="1">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text="2"
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/flip_digit_gap"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text=":"
        android:textColor="@color/flip_digit_text_light"
        android:textSize="44sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text="0"
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/flip_digit_gap"
                android:layout_weight="1">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/flip_digit_bg_light"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="8dp"
                    android:text="0"
                    android:textColor="@color/flip_digit_text_light"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/flip_hinge_line" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
