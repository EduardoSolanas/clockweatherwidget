<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark tile -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/flip_tile_dark_base" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Top half lighter / bottom half darker — classic split-flap tile -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/flip_tile_dark_surface_top"
                android:centerColor="@color/flip_tile_dark_surface_top"
                android:centerY="0.48"
                android:endColor="@color/flip_tile_dark_surface_bottom" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Stronger top-half shade -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/flip_tile_dark_top_shade_start"
                android:centerColor="@color/flip_tile_dark_top_shade_center"
                android:centerY="0.50"
                android:endColor="@android:color/transparent" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Top surface contour highlight (curved look) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/flip_tile_dark_highlight_start"
                android:centerColor="@color/flip_tile_dark_highlight_center"
                android:centerY="0.34"
                android:endColor="@android:color/transparent" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Side-edge vignette to avoid flat slab look -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/flip_tile_dark_side_vignette"
                android:centerColor="@android:color/transparent"
                android:centerX="0.50"
                android:endColor="@color/flip_tile_dark_side_vignette" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/flip_tile_dark_mid_shadow_start"
                android:centerColor="@color/flip_tile_dark_mid_shadow_center"
                android:centerY="0.50"
                android:endColor="@android:color/transparent" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Top-edge highlight — light catch on the upper tile surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/flip_tile_dark_top_edge_highlight"
                android:centerColor="@android:color/transparent"
                android:centerY="0.20"
                android:endColor="@android:color/transparent" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Bottom-half shadow vignette — darkens the lower flap -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:centerColor="@android:color/transparent"
                android:centerY="0.55"
                android:endColor="@color/flip_tile_dark_bottom_shadow" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Sharp center crease shadow — the hinge gap -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/flip_tile_dark_crease"
                android:centerY="0.50"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- Hairline highlight just above center — top-flap bottom edge catches light -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:centerColor="@color/flip_tile_dark_crease_highlight"
                android:centerY="0.485"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- Subtle outer border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="@color/flip_tile_dark_border" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</layer-list>
