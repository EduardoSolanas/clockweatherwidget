<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Overall base shape -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1F1F1F" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>

    <!-- 50% Split Gradient for 3D appearance -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#1AFFFFFF"
                android:centerColor="#0DFFFFFF"
                android:centerY="0.5"
                android:endColor="#26000000" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Perfectly Centered Fold Line -->
    <item android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <!-- This gradient has a very sharp transition at 50% to simulate a depth crease -->
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#AA000000"
                android:centerY="0.5"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Hairline highlight at center -->
    <item android:top="0dp" android:bottom="0dp">
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#26FFFFFF"
                android:centerY="0.51"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
