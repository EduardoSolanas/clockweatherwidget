<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark tile -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Top half lighter / bottom half darker — classic split-flap tile -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#353535"
                android:centerColor="#353535"
                android:centerY="0.48"
                android:endColor="#0F0F0F" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Top-edge highlight — light catch on the upper tile surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#28FFFFFF"
                android:centerColor="#00000000"
                android:centerY="0.20"
                android:endColor="#00000000" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Bottom-half shadow vignette — darkens the lower flap -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#00000000"
                android:centerY="0.55"
                android:endColor="#40000000" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Sharp center crease shadow — the hinge gap -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#F0000000"
                android:centerY="0.50"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Hairline highlight just above center — top-flap bottom edge catches light -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#45FFFFFF"
                android:centerY="0.485"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Subtle outer border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#22FFFFFF" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</layer-list>
