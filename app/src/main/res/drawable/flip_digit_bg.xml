<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Overall base shape -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1F1F1F" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>

    <!-- Sharp Top/Bottom split for 3D appearance -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#333333" 
                android:centerColor="#333333"
                android:centerY="0.50"
                android:endColor="#1F1F1F" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Pronounced Center Crease Shadow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#DF000000"
                android:centerY="0.5"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Hairline highlight at center edge -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#40FFFFFF"
                android:centerY="0.51"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
