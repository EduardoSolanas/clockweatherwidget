<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Clock tile area -->
    <item
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="88dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/weather_card_bg_color" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_glass_stroke" />
        </shape>
    </item>

    <!-- Clock digit bar -->
    <item
        android:left="32dp"
        android:top="28dp"
        android:right="32dp"
        android:bottom="106dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text_primary" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- Weather card area -->
    <item
        android:left="16dp"
        android:top="124dp"
        android:right="16dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/weather_card_bg_color" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_glass_stroke" />
        </shape>
    </item>

    <!-- Location text placeholder -->
    <item
        android:left="36dp"
        android:top="146dp"
        android:right="120dp"
        android:bottom="38dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text_primary" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Glass weather icon -->
    <item
        android:left="76dp"
        android:top="96dp"
        android:right="76dp"
        android:bottom="20dp"
        android:drawable="@drawable/ic_widget_weather_clear_day" />
</layer-list>
