        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M14,2.2v2M14,19.8v2M2.8,12h2M23.2,12h2M5.9,5.1l1.4,1.4M20.7,17.5l1.4,1.4M22.1,5.1l-1.4,1.4M7.3,17.5l-1.4,1.4" />

