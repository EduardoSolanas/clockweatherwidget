    <!-- rim shadow -->
    <path
        android:strokeColor="#20D07000"
        android:strokeWidth="0.6"
        android:pathData="M14,6.2a5.8,5.8 0 1,0 0,11.6a5.8,5.8 0 1,0 0,-11.6z" />

