<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<item>
		<shape android:shape="rectangle">
			<solid android:color="#F7F7F7" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<gradient
				android:angle="270"
				android:startColor="#30FFFFFF"
				android:centerColor="#14FFFFFF"
				android:centerY="0.46"
				android:endColor="#16000000" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<gradient
				android:angle="0"
				android:startColor="#12000000"
				android:centerColor="#00000000"
				android:centerX="0.50"
				android:endColor="#12000000" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<stroke
				android:width="1dp"
				android:color="#16000000" />
			<corners android:radius="8dp" />
		</shape>
	</item>
</layer-list>

