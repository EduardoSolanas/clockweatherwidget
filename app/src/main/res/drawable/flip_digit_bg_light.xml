<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<item>
		<shape android:shape="rectangle">
			<solid android:color="@color/flip_tile_light_base" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<gradient
				android:angle="270"
				android:startColor="@color/flip_tile_light_highlight_start"
				android:centerColor="@color/flip_tile_light_highlight_center"
				android:centerY="0.46"
				android:endColor="@color/flip_tile_light_highlight_end" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<gradient
				android:angle="0"
				android:startColor="@color/flip_tile_light_side_shade"
				android:centerColor="@android:color/transparent"
				android:centerX="0.50"
				android:endColor="@color/flip_tile_light_side_shade" />
			<corners android:radius="8dp" />
		</shape>
	</item>

	<item>
		<shape android:shape="rectangle">
			<stroke
				android:width="1dp"
				android:color="@color/flip_tile_light_border" />
			<corners android:radius="8dp" />
		</shape>
	</item>
</layer-list>

