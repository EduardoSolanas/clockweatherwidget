<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Clock tile area -->
    <item
        android:left="18dp"
        android:top="14dp"
        android:right="18dp"
        android:bottom="70dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/weather_card_bg_color" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_glass_stroke" />
        </shape>
    </item>

    <!-- Clock digit bar -->
    <item
        android:left="36dp"
        android:top="30dp"
        android:right="36dp"
        android:bottom="88dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text_primary" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Weather card area -->
    <item
        android:left="18dp"
        android:top="104dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/weather_card_bg_color" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/widget_glass_stroke" />
        </shape>
    </item>

    <!-- Location text placeholder -->
    <item
        android:left="36dp"
        android:top="126dp"
        android:right="110dp"
        android:bottom="40dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_text_primary" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <!-- Glass weather icon -->
    <item
        android:left="80dp"
        android:top="88dp"
        android:right="80dp"
        android:bottom="24dp"
        android:drawable="@drawable/ic_widget_weather_clear_day" />
</layer-list>
