<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:shareInterpolator="false">
    <!--
        Mechanical split-flap IN: the new digit unfolds downward from the top hinge,
        with a more pronounced overshoot bounce when it lands — mimicking a heavy
        retro flap clacking into place. Pivot at top edge (0 %) so it grows downward.
    -->
    <scale
        android:startOffset="100"
        android:duration="400"
        android:fromXScale="1.0"
        android:toXScale="1.0"
        android:fromYScale="0.0"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="0%"
        android:interpolator="@android:anim/overshoot_interpolator" />
    <alpha
        android:startOffset="100"
        android:duration="200"
        android:fromAlpha="0.0"
        android:toAlpha="1.0"
        android:interpolator="@android:anim/decelerate_interpolator" />
</set>
